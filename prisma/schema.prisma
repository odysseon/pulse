// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// @odysseon/whoami-adapter-prisma
// ============================================
// ============================================
// @odysseon/whoami-adapter-prisma
// Auth Tables Fragment
// ============================================
// This file is automatically appended to your schema.prisma
// Do not edit directly — changes will be preserved but overwritten on update
// ============================================

model Account {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  // Auth relations (internal — do not query directly)
  passwordHash PasswordHash?
  resetTokens  PasswordResetToken[]
  oauthCreds   OAuthCredential[]
  magicLinks   MagicLinkToken[]

  user User?
}

model PasswordHash {
  id        String   @id @default(cuid())
  accountId String   @unique
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  hash      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("password_hashes")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
  @@index([accountId])
  @@map("password_reset_tokens")
}

model OAuthCredential {
  id         String   @id @default(cuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  provider   String
  providerId String
  createdAt  DateTime @default(now())

  @@unique([provider, providerId])
  @@index([accountId])
  @@map("oauth_credentials")
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
  @@index([accountId])
  @@map("magic_link_tokens")
}

// ============================================
// End of @odysseon/whoami-adapter-prisma
// ============================================

enum PlatformRole {
  USER
  MODERATOR
  ADMIN
}

model User {
  id String @id @default(cuid())

  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  name String

  avatarUrl String?
  avatarId  String?

  phoneNumber String?

  role PlatformRole @default(USER)

  // Commercial identities owned by this user
  businessProfiles BusinessProfile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
}

// ==========================================
// COMMERCIAL / BUSINESS LAYER
// ==========================================

enum BusinessType {
  INDIVIDUAL
  RETAILER
  DISTRIBUTOR
  MANUFACTURER
  WHOLESALER
  AGENCY
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model BusinessProfile {
  id String @id @default(cuid())

  // ==========================================
  // Ownership
  // ==========================================
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // ==========================================
  // Public Identity
  // ==========================================
  name String
  slug String @unique

  description String?

  type BusinessType @default(INDIVIDUAL)

  // ==========================================
  // Branding
  // ==========================================
  logoUrl String?
  logoId  String?

  bannerUrl String?
  bannerId  String?

  // ==========================================
  // Contact / Trust
  // ==========================================
  email String?

  phoneNumber String?
  whatsapp    String?

  location String?

  verificationStatus VerificationStatus @default(UNVERIFIED)

  // ==========================================
  // Visibility
  // ==========================================
  isPublic Boolean @default(true)

  // ==========================================
  // Marketplace Relations
  // ==========================================
  listings Listing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([slug])
  @@index([verificationStatus])
}

// ==========================================
// CATEGORY / TAXONOMY LAYER
// ==========================================

model Category {
  id String @id @default(cuid())

  slug String @unique
  name String

  description String?

  // Hierarchical taxonomy
  parentId String?
  parent   Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])

  children Category[] @relation("CategoryHierarchy")

  // Blueprint attributes
  attributes CategoryAttribute[]

  listings Listing[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AttributeType {
  STRING
  NUMBER
  BOOLEAN
  SELECT
}

model CategoryAttribute {
  id String @id @default(cuid())

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  key         String
  label       String
  description String?

  type AttributeType

  isRequired Boolean @default(false)

  // Used for SELECT options
  options Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, key])
}

// ==========================================
// LISTING / DISCOVERY LAYER
// ==========================================

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  SUSPENDED
}

model Listing {
  id String @id @default(cuid())

  slug String @unique

  title       String
  description String?

  // ==========================================
  // Category
  // ==========================================
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  // ==========================================
  // Ownership
  // ==========================================
  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  // ==========================================
  // Commercial Data
  // ==========================================
  priceMin Float?
  priceMax Float?

  currency String @default("NGN")

  // ==========================================
  // Dynamic Attributes
  // ==========================================
  attributes Json @default("{}")

  // ==========================================
  // Visibility / Moderation
  // ==========================================
  status ListingStatus @default(DRAFT)

  isVerified Boolean @default(false)

  // ==========================================
  // Relations
  // ==========================================
  media Media[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([businessProfileId])
  @@index([status])
  @@index([categoryId, status])
  @@index([attributes], type: Gin)
}

// ==========================================
// MEDIA LAYER
// ==========================================

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

model Media {
  id String @id @default(cuid())

  publicId String @unique
  url      String

  type MediaType @default(IMAGE)

  order Int @default(0)

  caption String?

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([listingId])
}
