// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// @odysseon/whoami-adapter-prisma
// ============================================
// ============================================
// @odysseon/whoami-adapter-prisma
// Auth Tables Fragment
// ============================================
// This file is automatically appended to your schema.prisma
// Do not edit directly — changes will be preserved but overwritten on update
// ============================================

model Account {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  // Auth relations (internal — do not query directly)
  passwordHash PasswordHash?
  resetTokens  PasswordResetToken[]
  oauthCreds   OAuthCredential[]
  magicLinks   MagicLinkToken[]

  user User?
}

model PasswordHash {
  id        String   @id @default(cuid())
  accountId String   @unique
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  hash      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("password_hashes")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
  @@index([accountId])
  @@map("password_reset_tokens")
}

model OAuthCredential {
  id         String   @id @default(cuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  provider   String
  providerId String
  createdAt  DateTime @default(now())

  @@unique([provider, providerId])
  @@index([accountId])
  @@map("oauth_credentials")
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
  @@index([accountId])
  @@map("magic_link_tokens")
}

// ============================================
// End of @odysseon/whoami-adapter-prisma
// ============================================

enum Role {
  USER
  VENUE_OWNER
  ADMIN
}

model User {
  id        String  @id @default(cuid())
  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  name String
  role Role   @default(VENUE_OWNER)

  // A venue owner can manage multiple venues
  venues EventCentre[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- CORE PRODUCT LAYER ---

model EventCentre {
  id   String @id @default(cuid())
  slug String @unique

  // Core Info
  name        String
  description String?
  location    String // e.g., "Ikeja", "Lekki" (Good for fast filtering)
  address     String
  capacity    Int

  // Pricing Range
  priceRangeMin Float?
  priceRangeMax Float?

  // Conversion / Contact
  contactPhone    String?
  contactWhatsapp String?

  // Trust Signal
  isVerified Boolean @default(false)

  // Relations
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  media     VenueMedia[]
  perks     Perk[]
  amenities Amenity[] // Implicit Many-to-Many

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([location, capacity]) // Optimize for discovery/filtering
}

enum MediaType {
  IMAGE
  VIDEO
}

model VenueMedia {
  id      String    @id @default(cuid())
  url     String
  type    MediaType @default(IMAGE)
  caption String?
  order   Int       @default(0) // Crucial for "mainImage" sorting

  eventCentreId String
  eventCentre   EventCentre @relation(fields: [eventCentreId], references: [id], onDelete: Cascade)

  @@index([eventCentreId])
}

model Amenity {
  id   String @id @default(cuid())
  name String @unique // e.g., "Parking", "AC", "Generator"

  venues EventCentre[]
}

model Perk {
  id          String  @id @default(cuid())
  title       String // e.g., "Free Photography"
  description String? // e.g., "6 hours coverage included"

  eventCentreId String
  eventCentre   EventCentre @relation(fields: [eventCentreId], references: [id], onDelete: Cascade)

  @@index([eventCentreId])
}
