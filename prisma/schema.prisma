// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// @odysseon/whoami-adapter-prisma
// ============================================

model Account {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  passwordHash PasswordHash?
  resetTokens  PasswordResetToken[]
  oauthCreds   OAuthCredential[]
  magicLinks   MagicLinkToken[]

  user User?
}

model PasswordHash {
  id        String   @id @default(cuid())
  accountId String   @unique
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  hash      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("password_hashes")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
  @@index([accountId])
  @@map("password_reset_tokens")
}

model OAuthCredential {
  id         String   @id @default(cuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  provider   String
  providerId String
  createdAt  DateTime @default(now())

  @@unique([provider, providerId])
  @@index([accountId])
  @@map("oauth_credentials")
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
  @@index([accountId])
  @@map("magic_link_tokens")
}

// ============================================
// End of @odysseon/whoami-adapter-prisma
// ============================================

enum PlatformRole {
  USER
  MODERATOR
  ADMIN
}

model User {
  id String @id @default(cuid())

  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  name        String
  avatarUrl   String?
  avatarId    String?
  phoneNumber String?

  role PlatformRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessProfiles BusinessProfile[]
  reviewsGiven     Review[]          @relation("ReviewsGiven")

  @@index([accountId])
}

// ============================================
// Business Profile
// ============================================

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

model BusinessProfile {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name String
  slug String @unique

  // Trust signal — not a permission or role
  verificationStatus VerificationStatus @default(UNVERIFIED)

  isPublic    Boolean @default(false)
  description String?

  // External contact — Pulse does not execute commerce
  phoneNumber String?
  whatsapp    String?
  email       String?
  location    String?

  // Geography — for proximity queries
  latitude  Float?
  longitude Float?

  // Commercial identity — leaf category only (see Category constraints)
  categoryId String?
  category   Category? @relation("BusinessProfileCategory", fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings Listing[]
  hours    OperatingHours[]
  tags     BusinessProfileTag[]
  reviews  Review[]
  media    Media[]              @relation("BusinessProfileMedia")

  @@index([ownerId])
  @@index([slug])
  @@index([verificationStatus])
  @@index([isPublic])
  @@index([categoryId])
  @@index([latitude, longitude])
  @@map("business_profiles")
}

// ============================================
// Listing
// ============================================

enum ListingStatus {
  DRAFT
  PUBLISHED
  PAUSED
  ARCHIVED
}

enum Currency {
  NGN
  USD
  GBP
  EUR
}

model Listing {
  id String @id @default(cuid())

  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  title       String
  slug        String
  description String?

  status ListingStatus @default(DRAFT)

  // Prices stored as Decimal for monetary precision
  minPrice     Decimal?  @db.Decimal(18, 2)
  maxPrice     Decimal?  @db.Decimal(18, 2)
  currency     Currency?
  isNegotiable Boolean   @default(false)

  // Offering type — leaf category only (see Category constraints)
  categoryId String?
  category   Category? @relation("ListingCategory", fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessProfileId, slug])
  @@index([businessProfileId])
  @@index([status])
  @@index([currency])
  @@index([minPrice])
  @@index([maxPrice])
  @@index([isNegotiable])
  @@index([categoryId])
  @@map("listings")
}

// ============================================
// Media
// ============================================

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaResourceType {
  LISTING
  BUSINESS_PROFILE
  REVIEW
}

enum MediaRole {
  /// BusinessProfile only — singleton
  LOGO
  /// BusinessProfile only — singleton
  BANNER
  /// Listing only — singleton
  COVER
  /// Both resource types — reorderable multi-items
  GALLERY
}

model Media {
  id String @id @default(cuid())

  // Polymorphic ownership
  resourceType MediaResourceType
  resourceId   String

  url    String
  fileId String

  mediaType MediaType

  // Semantic role — determines cardinality and display context
  role MediaRole

  // Display sequence — only meaningful for GALLERY role items
  // null for singleton roles (LOGO, BANNER, COVER)
  order Int?

  createdAt DateTime @default(now())

  businessProfile BusinessProfile? @relation("BusinessProfileMedia", fields: [resourceId], references: [id], onDelete: Cascade, map: "media_business_profile_fk")
  review          Review?          @relation("ReviewMedia", fields: [resourceId], references: [id], onDelete: Cascade, map: "media_review_fk")

  @@index([resourceType, resourceId])
  @@index([resourceType, resourceId, order])
  @@index([resourceType, resourceId, role])
  @@map("media")
}

// ============================================
// Category
// ============================================

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  // Self-referential: null = root node; non-null = leaf node
  // Max depth = 2 enforced at application layer.
  // parentId must point to a root (parentId = null) — no grandparents.
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  // Display order within siblings
  order Int @default(0)

  // Soft-disable: inactive categories hidden from filters, not assignable to new entities.
  // Existing assignments are preserved.
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessProfiles BusinessProfile[] @relation("BusinessProfileCategory")
  listings         Listing[]         @relation("ListingCategory")

  @@index([parentId])
  @@index([slug])
  @@index([isActive])
  @@map("categories")
}

// ============================================
// Review
// ============================================

model Review {
  id String @id @default(cuid())

  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  reviewerId String
  reviewer   User   @relation("ReviewsGiven", fields: [reviewerId], references: [id])

  // 1–5, enforced at application layer
  rating  Int
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media Media[] @relation("ReviewMedia")

  // One review per business per user
  @@unique([businessProfileId, reviewerId])
  @@index([businessProfileId])
  @@index([reviewerId])
  @@map("reviews")
}

// ============================================
// Tag
// ============================================

model Tag {
  id   String @id @default(cuid())
  name String @unique // normalised lowercase e.g. "sedan", "certified", "luxury"
  slug String @unique

  businesses BusinessProfileTag[]

  @@map("tags")
}

model BusinessProfileTag {
  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([businessProfileId, tagId])
  @@map("business_profile_tags")
}

// ============================================
// Operating Hours
// ============================================

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model OperatingHours {
  id String @id @default(cuid())

  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  day       DayOfWeek
  openTime  String    // "09:00" — HH:mm, UTC
  closeTime String    // "17:00" — HH:mm, UTC
  isClosed  Boolean   @default(false) // explicit closure override for this day

  @@unique([businessProfileId, day])
  @@index([businessProfileId])
  @@map("operating_hours")
}
