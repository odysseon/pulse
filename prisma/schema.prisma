// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

// ============================================
// @odysseon/whoami-adapter-prisma
// ============================================

model Account {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  passwordHash PasswordHash?
  resetTokens  PasswordResetToken[]
  oauthCreds   OAuthCredential[]
  magicLinks   MagicLinkToken[]

  user User?
}

model PasswordHash {
  id        String   @id @default(cuid())
  accountId String   @unique
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  hash      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("password_hashes")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
  @@index([accountId])
  @@map("password_reset_tokens")
}

model OAuthCredential {
  id         String   @id @default(cuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  provider   String
  providerId String
  createdAt  DateTime @default(now())

  @@unique([provider, providerId])
  @@index([accountId])
  @@map("oauth_credentials")
}

model MagicLinkToken {
  id        String    @id @default(cuid())
  accountId String
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
  @@index([accountId])
  @@map("magic_link_tokens")
}

// ============================================
// End of @odysseon/whoami-adapter-prisma
// ============================================

enum PlatformRole {
  USER
  MODERATOR
  ADMIN
}

model User {
  id String @id @default(cuid())

  accountId String  @unique
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  name        String
  avatarUrl   String?
  avatarId    String?
  phoneNumber String?

  role PlatformRole @default(USER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessProfiles  BusinessProfile[]
  businessDrafts    BusinessProfileDraft[]
  reviewsGiven      Review[]               @relation("ReviewsGiven")
  storeToursCreated StoreTour[]

  @@index([accountId])
}

// ============================================
// Business Profile
// ============================================

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum BusinessType {
  ONLINE
  PHYSICAL
  HYBRID
}

model BusinessProfile {
  id String @id @default(cuid())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name String
  slug String @unique

  // Trust signal — not a permission or role
  verificationStatus VerificationStatus @default(UNVERIFIED)

  isPublic     Boolean      @default(false)
  description  String?
  businessType BusinessType
  websiteUrl   String?

  isEmailVerified Boolean @default(false)
  isPhoneVerified Boolean @default(false)

  // External contact — Pulse does not execute commerce
  phoneNumber String
  whatsapp    String
  email       String
  // Physical location using PostGIS
  locationId  String?
  geoEntity   Location? @relation(fields: [locationId], references: [id])

  // Commercial identity — leaf category only (see Category constraints)
  categoryId String?
  category   Category?   @relation("BusinessProfileCategory", fields: [categoryId], references: [id])
  storeTours StoreTour[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings Listing[]
  hours    OperatingHours[]
  tags     BusinessProfileTag[]
  media    Media[]

  @@index([ownerId])
  @@index([slug])
  @@index([verificationStatus])
  @@index([isPublic])
  @@index([categoryId])
  @@index([locationId])
  @@map("business_profiles")
}

model Location {
  id               String                               @id @default(cuid())
  name             String
  formattedAddress String
  placeId          String?
  city             String?
  state            String?
  country          String?
  coordinates      Unsupported("geometry(Point, 4326)")

  businessProfiles BusinessProfile[]
}

model BusinessProfileDraft {
  id        String   @id @default(cuid())
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  data      Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@map("business_profile_drafts")
}

// ============================================
// Listing
// ============================================

enum ListingStatus {
  DRAFT
  PUBLISHED
  PAUSED
  ARCHIVED
}

model Listing {
  id String @id @default(cuid())

  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  title       String
  slug        String
  description String?

  status ListingStatus @default(DRAFT)
  media  Media[]

  // Prices stored as Decimal for monetary precision
  minPrice     Decimal? @db.Decimal(18, 2)
  maxPrice     Decimal? @db.Decimal(18, 2)
  currencyCode String?
  isNegotiable Boolean  @default(false)

  // Dynamic attributes corresponding to CategoryAttribute schema
  attributes   Json?    @db.JsonB

  // Offering type — leaf category only (see Category constraints)
  categoryId String?
  category   Category? @relation("ListingCategory", fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews Review[]

  @@unique([businessProfileId, slug])
  @@index([businessProfileId])
  @@index([status])
  @@index([currencyCode])
  @@index([minPrice])
  @@index([maxPrice])
  @@index([isNegotiable])
  @@index([categoryId])
  @@map("listings")
}

// ============================================
// Media
// ============================================

enum MediaType {
  IMAGE
  VIDEO
}

enum MediaRole {
  /// BusinessProfile only — singleton
  LOGO
  /// BusinessProfile only — singleton
  BANNER
  /// Listing only — singleton
  COVER
  /// Both resource types — reorderable multi-items
  GALLERY
}

model Media {
  id String @id @default(cuid())

  url    String
  fileId String

  mediaType MediaType
  role      MediaRole

  order Int?

  businessProfileId String?
  businessProfile   BusinessProfile? @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)

  storeTourId String?
  storeTour   StoreTour? @relation(fields: [storeTourId], references: [id], onDelete: Cascade)

  reviewId String?
  review   Review? @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([businessProfileId])
  @@index([listingId])
  @@index([storeTourId])
  @@map("media")
}

// ============================================
// Category
// ============================================

model Category {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  // Self-referential: null = root node; non-null = leaf node
  // Max depth = 2 enforced at application layer.
  // parentId must point to a root (parentId = null) — no grandparents.
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  // Display order within siblings
  order Int @default(0)

  // Soft-disable: inactive categories hidden from filters, not assignable to new entities.
  // Existing assignments are preserved.
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessProfiles BusinessProfile[] @relation("BusinessProfileCategory")
  listings         Listing[]         @relation("ListingCategory")
  attributes       CategoryAttribute[]

  @@index([parentId])
  @@index([slug])
  @@index([isActive])
  @@map("categories")
}

// ============================================
// Category Attributes
// ============================================

enum AttributeType {
  STRING
  NUMBER
  BOOLEAN
  SELECT
}

model CategoryAttribute {
  id         String   @id @default(cuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  key          String        // e.g., "capacity", "condition"
  label        String        // e.g., "Guest Capacity", "Item Condition"
  type         AttributeType
  isRequired   Boolean       @default(false)
  displayOrder Int           @default(0)

  // For SELECT: flat array e.g., ["New", "Used", "Refurbished"]
  options      Json?

  @@unique([categoryId, key])
  @@index([categoryId])
  @@map("category_attributes")
}

// ============================================
// Review
// ============================================

model Review {
  id String @id @default(cuid())

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  reviewerId String
  reviewer   User   @relation("ReviewsGiven", fields: [reviewerId], references: [id])

  // 1–5, enforced at application layer
  rating  Int
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media Media[]

  @@unique([listingId, reviewerId])
  @@index([reviewerId])
  @@index([listingId])
  @@map("reviews")
}

enum StoreTourStatus {
  DRAFT
  PUBLISHED
}

model StoreTour {
  id String @id @default(cuid())

  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  title String

  summary String?

  visitDate DateTime

  status StoreTourStatus @default(DRAFT)

  publishedAt DateTime?

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  highlights StoreTourHighlight[]

  media Media[]

  @@index([businessProfileId])
  @@index([status])
  @@map("store_tours")
}

model StoreTourHighlight {
  id String @id @default(cuid())

  storeTourId String
  storeTour   StoreTour @relation(fields: [storeTourId], references: [id], onDelete: Cascade)

  value String

  @@index([storeTourId])
  @@map("store_tour_highlights")
}

// ============================================
// Tag
// ============================================

model Tag {
  id   String @id @default(cuid())
  name String @unique // normalised lowercase e.g. "sedan", "certified", "luxury"
  slug String @unique

  businesses BusinessProfileTag[]

  @@map("tags")
}

model BusinessProfileTag {
  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  tagId String
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([businessProfileId, tagId])
  @@map("business_profile_tags")
}

// ============================================
// Operating Hours
// ============================================

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model OperatingHours {
  id String @id @default(cuid())

  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  day       DayOfWeek
  openTime  String // "09:00" — HH:mm, UTC
  closeTime String // "17:00" — HH:mm, UTC
  isClosed  Boolean   @default(false) // explicit closure override for this day

  @@unique([businessProfileId, day])
  @@index([businessProfileId])
  @@map("operating_hours")
}
